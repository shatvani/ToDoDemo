root = true

[*]
charset = utf-8
end_of_line = crlf
indent_style = space
trim_trailing_whitespace = true
insert_final_newline = true

[*.{cs,csx}]
indent_size = 4

# C# coding conventions
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

# Naming conventions
dotnet_naming_rule.interfaces_should_be_prefixed_with_i.severity = error
dotnet_naming_rule.interfaces_should_be_prefixed_with_i.symbols = interface
dotnet_naming_rule.interfaces_should_be_prefixed_with_i.style = prefix_with_i
dotnet_naming_symbols.interface.applicable_kinds = interface
dotnet_naming_style.prefix_with_i.required_prefix = I
dotnet_naming_style.prefix_with_i.capitalization = pascal_case

dotnet_naming_rule.types_should_be_pascal_case.severity = error
dotnet_naming_rule.types_should_be_pascal_case.symbols = types
dotnet_naming_rule.types_should_be_pascal_case.style = pascal_case
dotnet_naming_symbols.types.applicable_kinds = class,struct,enum,delegate
dotnet_naming_style.pascal_case.capitalization = pascal_case

dotnet_naming_rule.private_fields_camel_underscore.severity = warning
dotnet_naming_rule.private_fields_camel_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_camel_underscore.style = camel_underscore
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.camel_underscore.required_prefix = _
dotnet_naming_style.camel_underscore.capitalization = camel_case

# var usage
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:suggestion

# Expression-bodied members
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion

# Null checks
dotnet_style_null_propagation = true:suggestion
dotnet_style_coalesce_expression = true:suggestion
csharp_style_throw_expression = true:suggestion
csharp_style_conditional_delegate_call = true:suggestion

# Braces
csharp_prefer_braces = true:error

# New lines
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true

# Spacing
csharp_space_after_cast = false
csharp_space_before_colon_in_inheritance_clause = true
csharp_space_after_colon_in_inheritance_clause = true
csharp_space_around_binary_operators = before_and_after

# Indentation
csharp_indent_case_contents = true
csharp_indent_switch_labels = true

# Diagnostic suppressions
dotnet_diagnostic.CS1591.severity = none   # Missing XML comment — opt-in per project

# StyleCop suppressions (noisy rules disabled for this project)
dotnet_diagnostic.SA1633.severity = none   # File header copyright — not required
dotnet_diagnostic.SA1200.severity = none   # Using directives placement — top-level statements
dotnet_diagnostic.SA1101.severity = none   # Prefix local calls with this — too noisy
dotnet_diagnostic.SA1309.severity = none   # Field names must not begin with underscore — conflicts with _field convention
dotnet_diagnostic.SX1309.severity = warning  # Field names must begin with underscore (alternative rule)
dotnet_diagnostic.SA1600.severity = none   # Elements must be documented — opt-in
dotnet_diagnostic.SA1601.severity = none   # Partial elements must be documented
dotnet_diagnostic.SA1602.severity = none   # Enumeration items must be documented

[*.{json,yml,yaml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

# Az EF Core által generált migrációs fájlokat generált kódként kezeljük,
# így a StyleCop és a többi analyzer nem fut rájuk.
[**/Migrations/*.cs]
generated_code = true