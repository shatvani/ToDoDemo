@model TodoApi.DTOs.TodoItemDto

@{
    var tagsRaw = Model.Tags is { Length: > 0 } ? string.Join(", ", Model.Tags) : string.Empty;
    var dueDateValue = Model.DueDate.HasValue ? Model.DueDate.Value.ToLocalTime().ToString("yyyy-MM-dd") : string.Empty;
}

<div id="card-@Model.Id" class="bg-white rounded-xl shadow-sm border border-blue-200 p-5 flex flex-col gap-4">

    <form hx-put="/todos/edit/@Model.Id"
          hx-target="#card-@Model.Id"
          hx-swap="outerHTML"
          class="flex flex-col gap-4">

        <div class="flex flex-col gap-1">
            <label for="title-@Model.Id" class="text-xs font-medium text-gray-500 uppercase tracking-wide">
                Cím <span class="text-red-500">*</span>
            </label>
            <input id="title-@Model.Id" name="title" type="text" required value="@Model.Title"
                   class="rounded-lg border border-gray-200 px-3 py-2 text-sm text-gray-700 placeholder-gray-300 focus:outline-none focus:ring-2 focus:ring-blue-400" />
        </div>

        <div class="flex flex-col gap-1">
            <label for="description-@Model.Id" class="text-xs font-medium text-gray-500 uppercase tracking-wide">Leírás</label>
            <textarea id="description-@Model.Id" name="description" rows="3"
                      class="rounded-lg border border-gray-200 px-3 py-2 text-sm text-gray-700 placeholder-gray-300 focus:outline-none focus:ring-2 focus:ring-blue-400 resize-none">@Model.Description</textarea>
        </div>

        <div class="flex flex-wrap gap-4">

            <div class="flex flex-col gap-1 flex-1 min-w-32">
                <label for="priority-@Model.Id" class="text-xs font-medium text-gray-500 uppercase tracking-wide">
                    Prioritás <span class="text-red-500">*</span>
                </label>
                <select id="priority-@Model.Id" name="priority" required
                        class="rounded-lg border border-gray-200 px-3 py-2 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-400">
                    <option value="Low"    selected="@(Model.Priority == "Low")">Alacsony</option>
                    <option value="Medium" selected="@(Model.Priority == "Medium")">Közepes</option>
                    <option value="High"   selected="@(Model.Priority == "High")">Magas</option>
                    <option value="Urgent" selected="@(Model.Priority == "Urgent")">Kritikus</option>
                </select>
            </div>

            <div class="flex flex-col gap-1 flex-1 min-w-36">
                <label for="dueDate-@Model.Id" class="text-xs font-medium text-gray-500 uppercase tracking-wide">Határidő</label>
                <input id="dueDate-@Model.Id" name="dueDate" type="date" value="@dueDateValue"
                       class="rounded-lg border border-gray-200 px-3 py-2 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-400" />
            </div>

        </div>

        <div class="flex flex-col gap-1">
            <label for="tagsRaw-@Model.Id" class="text-xs font-medium text-gray-500 uppercase tracking-wide">Címkék</label>
            <input id="tagsRaw-@Model.Id" name="tagsRaw" type="text" value="@tagsRaw"
                   placeholder="pl. urgent, fontos"
                   class="rounded-lg border border-gray-200 px-3 py-2 text-sm text-gray-700 placeholder-gray-300 focus:outline-none focus:ring-2 focus:ring-blue-400" />
        </div>

        <div class="flex gap-3 pt-1">
            <button type="submit"
                    class="rounded-lg px-5 py-2 text-sm font-medium text-white transition hover:opacity-90"
                    style="background-color: #12326e;">
                Mentés
            </button>
            <button type="button"
                    hx-get="/todos/card/@Model.Id"
                    hx-target="#card-@Model.Id"
                    hx-swap="outerHTML"
                    class="rounded-lg border border-gray-200 px-5 py-2 text-sm font-medium text-gray-500 hover:bg-gray-50 transition">
                Mégse
            </button>
        </div>

    </form>

</div>
